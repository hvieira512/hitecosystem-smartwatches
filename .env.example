# Server
WS_HOST=0.0.0.0
WS_PORT=8080
VIVISTAR_TCP_HOST=0.0.0.0
VIVISTAR_TCP_PORT=9000
API_HOST=0.0.0.0
API_PORT=8081

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=health_watches
DB_USER=health
DB_PASS=health_secret

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# WebSocket URL (used by API to reach WS process)
WS_SERVER_URL=ws://127.0.0.1:8080

# Logging
LOG_LEVEL=info
LOG_FILE=var/log/server.log
